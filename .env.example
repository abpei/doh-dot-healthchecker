# Required: Comma-separated server list
# https:// prefix = DoH, anything else = DoT (host:port or host with default port 853)
TARGETS=https://dns.google/dns-query,1.1.1.1:853

# Required: Comma-separated domain|expected_A_record pairs
TEST_DOMAINS=google.com|142.250.80.46,cloudflare.com|104.16.132.229

# Required: SMTP settings for alert emails (STARTTLS)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=doh-monitor@example.com
SMTP_TO=admin@example.com

# Optional: Seconds between probe cycles (default: 300)
# PROBE_INTERVAL=300

# Optional: Consecutive failures before sending alert email (default: 5)
# FAILURE_THRESHOLD=5

# Optional: Consecutive successes before sending recovery email (default: 3)
# RECOVERY_THRESHOLD=3

# Optional: DNS server for resolving DoT hostnames and PTR lookups (default: 1.1.1.1)
# DNS_SERVER=1.1.1.1

# Optional: Explicit override for DoT TLS SNI hostname (default: none)
# When set, takes priority over automatic PTR lookup. Normally not needed —
# raw IP targets are auto-resolved via PTR unless the server expects a
# different hostname than what the PTR record returns.
# DOT_HOSTNAME=pidoh.mapledns.net

# Optional: Disable TLS hostname verification on DoT connections (default: true)
# Only use when the target uses a self-signed or unverifiable certificate
# DOT_VERIFY_HOSTNAME=true
